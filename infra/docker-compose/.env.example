# Viaverse local environment example.
# Copy to .env.local for local development.
# Never put staging/production secrets in this file.

VIAVERSE_ENV=local
SPRING_PROFILES_ACTIVE=local
VIAVERSE_REPO_ROOT=.

POSTGRES_HOST=localhost
POSTGRES_USER=viaverse
POSTGRES_PASSWORD=viaverse
POSTGRES_DB=viaverse
POSTGRES_PORT=5432

VALKEY_PORT=6379

KAFKA_PORT=9092


MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

SEAWEEDFS_MASTER_PORT=9333
SEAWEEDFS_VOLUME_PORT=8080
SEAWEEDFS_FILER_PORT=8888
SEAWEEDFS_S3_PORT=8333

OBJECT_STORAGE_PROVIDER=seaweedfs
OBJECT_STORAGE_ENDPOINT=http://localhost:8333
OBJECT_STORAGE_REGION=local
OBJECT_STORAGE_ACCESS_KEY=viaverse
OBJECT_STORAGE_SECRET_KEY=viaverse-local-secret
OBJECT_STORAGE_BUCKET_MEDIA=viaverse-media-local
OBJECT_STORAGE_PATH_STYLE_ACCESS=true

OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_LOGS_EXPORTER=none
OTEL_TRACES_EXPORTER=none
OTEL_SERVICE_NAME=
PROMETHEUS_PORT=9090
OPENSEARCH_PORT=9200
OPENSEARCH_DASHBOARDS_PORT=5601
VIAVERSE_OBSERVABILITY_ENABLED=false


IDENTITY_SERVICE_DB_URL=jdbc:postgresql://localhost:5432/viaverse_identity
IDENTITY_SERVICE_DB_USERNAME=viaverse
IDENTITY_SERVICE_DB_PASSWORD=viaverse
IDENTITY_SERVICE_TEST_DB_URL=jdbc:postgresql://localhost:5432/viaverse_identity_test
IDENTITY_JWT_SECRET=local-dev-identity-jwt-secret-change-me
VIAVERSE_AUTH_DEBUG_ENABLED=true
VIAVERSE_AUTH_DEBUG_FIXED_OTP=111111
VIAVERSE_AUTH_DEBUG_SEED_USERS=true
VIAVERSE_SMS_PROVIDER=none
NETGSM_USERNAME=
NETGSM_PASSWORD=
NETGSM_HEADER=
VIAVERSE_EMAIL_PROVIDER=smtp
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM_ADDRESS=noreply@viaverse.local
SMTP_FROM_NAME=Viaverse
SMTP_AUTH_ENABLED=false
SMTP_STARTTLS_ENABLED=false
VIAVERSE_SOCIAL_GOOGLE_ENABLED=false
GOOGLE_OAUTH_CLIENT_ID=
VIAVERSE_SOCIAL_APPLE_ENABLED=false
APPLE_CLIENT_ID=
VIAVERSE_SOCIAL_INSTAGRAM_ENABLED=false
INSTAGRAM_CLIENT_ID=
VIAVERSE_AUTH_RATE_LIMIT_ENABLED=true
VIAVERSE_AUTH_START_IDENTIFIER_WINDOW_SECONDS=300
VIAVERSE_AUTH_START_IDENTIFIER_MAX_ATTEMPTS=3
VIAVERSE_AUTH_START_IP_WINDOW_SECONDS=60
VIAVERSE_AUTH_START_IP_MAX_ATTEMPTS=20
VIAVERSE_AUTH_OTP_FLOW_WINDOW_SECONDS=300
VIAVERSE_AUTH_OTP_FLOW_MAX_ATTEMPTS=5
VIAVERSE_AUTH_OTP_IP_WINDOW_SECONDS=60
VIAVERSE_AUTH_OTP_IP_MAX_ATTEMPTS=30
VIAVERSE_AUTH_OTP_RESEND_COOLDOWN_SECONDS=60
VIAVERSE_AUTH_LOCKOUT_DURATION_SECONDS=900

MARKETPLACE_SERVICE_DB_URL=jdbc:postgresql://localhost:5432/viaverse_marketplace
MARKETPLACE_SERVICE_DB_USERNAME=viaverse
MARKETPLACE_SERVICE_DB_PASSWORD=viaverse
MARKETPLACE_SERVICE_TEST_DB_URL=jdbc:postgresql://localhost:5432/viaverse_marketplace_test

