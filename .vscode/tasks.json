{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "gradle: clean",
      "type": "shell",
      "command": "${workspaceFolder}/gradlew.bat",
      "args": ["clean"],
      "group": "build",
      "problemMatcher": ["$javac"]
    },
    {
      "label": "gradle: projects",
      "type": "shell",
      "command": "${workspaceFolder}/gradlew.bat",
      "args": ["projects"],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "gradle: check all",
      "type": "shell",
      "command": "${workspaceFolder}/gradlew.bat",
      "args": ["check"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$javac"]
    },
    {
      "label": "docker: initial setup",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/dev/start-core-infra.ps1"
      ],
      "problemMatcher": []
    },
    {
      "label": "backend: ready",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/dev/start-core-infra.ps1"
      ],
      "problemMatcher": []
    },
    {
      "label": "infra: stop",
      "type": "shell",
      "command": "docker",
      "args": ["compose", "down"],
      "options": {
        "cwd": "${workspaceFolder}/infra/docker-compose"
      },
      "problemMatcher": []
    },
    {
      "label": "mobile-kmp: check",
      "type": "shell",
      "command": "${workspaceFolder}/gradlew.bat",
      "args": [":apps:mobile-kmp:check"],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "mobile-kmp: desktop",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/dev/start-mobile-desktop.ps1"
      ],
      "problemMatcher": []
    },
    {
      "label": "mobile-kmp: android",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/dev/start-mobile-android.ps1"
      ],
      "problemMatcher": []
    },
    {
      "label": "web-next: dev",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/dev/start-next-app.ps1",
        "-App",
        "web-next"
      ],
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "admin-next: dev",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/dev/start-next-app.ps1",
        "-App",
        "admin-next"
      ],
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}
