{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node-terminal",
      "name": "docker initial setup",
      "request": "launch",
      "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${workspaceFolder}\\scripts\\dev\\start-core-infra.ps1\"",
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "java",
      "name": "debug identity-service",
      "request": "launch",
      "mainClass": "app.viaverse.identity.IdentityServiceApplication",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "shortenCommandLine": "argfile",
      "envFile": "${workspaceFolder}/.env.local",
      "vmArgs": "-Dspring.profiles.active=local -Dspring.config.additional-location=file:${workspaceFolder}/services/identity-service/src/main/resources/",
      "preLaunchTask": "backend: ready identity-service"
    },
    {
      "type": "java",
      "name": "debug marketplace-service",
      "request": "launch",
      "mainClass": "app.viaverse.marketplace.MarketplaceServiceApplication",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "shortenCommandLine": "argfile",
      "envFile": "${workspaceFolder}/.env.local",
      "vmArgs": "-Dspring.profiles.active=local -Dspring.config.additional-location=file:${workspaceFolder}/services/marketplace-service/src/main/resources/",
      "preLaunchTask": "backend: ready marketplace-service"
    },
    {
      "type": "java",
      "name": "debug payment-service",
      "request": "launch",
      "mainClass": "app.viaverse.payment.PaymentServiceApplication",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "shortenCommandLine": "argfile",
      "envFile": "${workspaceFolder}/.env.local",
      "vmArgs": "-Dspring.profiles.active=local -Dspring.config.additional-location=file:${workspaceFolder}/services/payment-service/src/main/resources/",
      "preLaunchTask": "backend: ready payment-service"
    },
    {
      "type": "java",
      "name": "debug messaging-service",
      "request": "launch",
      "mainClass": "app.viaverse.messaging.MessagingServiceApplication",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "shortenCommandLine": "argfile",
