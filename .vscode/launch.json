      "vmArgs": "-Dspring.profiles.active=local -Dspring.config.additional-location=file:${workspaceFolder}/services/media-service/src/main/resources/",
      "preLaunchTask": "backend: ready media-service"
    },
    {
      "type": "java",
      "name": "debug notification-service",
      "request": "launch",
      "mainClass": "app.viaverse.notification.NotificationServiceApplication",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "shortenCommandLine": "argfile",
      "envFile": "${workspaceFolder}/.env.local",
      "vmArgs": "-Dspring.profiles.active=local -Dspring.config.additional-location=file:${workspaceFolder}/services/notification-service/src/main/resources/",
      "preLaunchTask": "backend: ready notification-service"
    },
    {
      "type": "java",
      "name": "debug search-service",
      "request": "launch",
      "mainClass": "app.viaverse.search.SearchServiceApplication",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "shortenCommandLine": "argfile",
      "envFile": "${workspaceFolder}/.env.local",
      "vmArgs": "-Dspring.profiles.active=local -Dspring.config.additional-location=file:${workspaceFolder}/services/search-service/src/main/resources/",
      "preLaunchTask": "backend: ready search-service"
    },
    {
      "type": "java",
      "name": "debug trust-gamification-service",
      "request": "launch",
      "mainClass": "app.viaverse.trustgamification.TrustGamificationServiceApplication",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "shortenCommandLine": "argfile",
      "envFile": "${workspaceFolder}/.env.local",
      "vmArgs": "-Dspring.profiles.active=local -Dspring.config.additional-location=file:${workspaceFolder}/services/trust-gamification-service/src/main/resources/",
      "preLaunchTask": "backend: ready trust-gamification-service"
    },
    {
      "type": "java",
      "name": "debug ads-monetization-service",
      "request": "launch",
      "mainClass": "app.viaverse.adsmonetization.AdsMonetizationServiceApplication",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "shortenCommandLine": "argfile",
      "envFile": "${workspaceFolder}/.env.local",
      "vmArgs": "-Dspring.profiles.active=local -Dspring.config.additional-location=file:${workspaceFolder}/services/ads-monetization-service/src/main/resources/",
