      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "shortenCommandLine": "argfile",
      "envFile": "${workspaceFolder}/.env.local",
      "vmArgs": "-Dspring.profiles.active=local -Dspring.config.additional-location=file:${workspaceFolder}/services/admin-bff/src/main/resources/",
      "preLaunchTask": "backend: ready admin-bff"
    },
    {
      "type": "node-terminal",
      "name": "run web-next",
      "request": "launch",
      "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${workspaceFolder}\\scripts\\dev\\start-next-app.ps1\" -App web-next",
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "node-terminal",
      "name": "run admin-next",
      "request": "launch",
      "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${workspaceFolder}\\scripts\\dev\\start-next-app.ps1\" -App admin-next",
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "node-terminal",
      "name": "run mobile-kmp desktop",
      "request": "launch",
      "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${workspaceFolder}\\scripts\\dev\\start-mobile-desktop.ps1\"",
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "node-terminal",
      "name": "run mobile-kmp android",
      "request": "launch",
      "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${workspaceFolder}\\scripts\\dev\\start-mobile-android.ps1\"",
      "cwd": "${workspaceFolder}"
    }
  ],
  "compounds": [
    {
      "name": "debug backend: all services",
      "configurations": [
        "debug identity-service",
        "debug marketplace-service",
        "debug payment-service",
        "debug messaging-service",
        "debug media-service",
        "debug notification-service",
        "debug search-service",
        "debug trust-gamification-service",
        "debug ads-monetization-service",
        "debug admin-bff"
      ],
      "stopAll": true
    },
    {
      "name": "run web apps",
      "configurations": [
        "run web-next",
        "run admin-next"
      ],
      "stopAll": true
    },
    {
      "name": "run local stack: backend + web apps",
      "configurations": [
        "debug identity-service",
        "debug marketplace-service",
        "debug payment-service",
        "debug messaging-service",
        "debug media-service",
        "debug notification-service",
        "debug search-service",
        "debug trust-gamification-service",
        "debug ads-monetization-service",
        "debug admin-bff",
        "run web-next",
        "run admin-next"
      ],
      "stopAll": true
    }
  ]
}
