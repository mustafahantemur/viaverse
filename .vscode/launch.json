      "vmArgs": "-Dspring.profiles.active=local -Dspring.config.additional-location=file:${workspaceFolder}/services/messaging-service/src/main/resources/",
      "preLaunchTask": "backend: ready messaging-service"
    },
    {
      "type": "java",
      "name": "debug media-service",
      "request": "launch",
      "mainClass": "app.viaverse.media.MediaServiceApplication",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "shortenCommandLine": "argfile",
